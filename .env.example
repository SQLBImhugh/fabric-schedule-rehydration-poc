# Copy to .env and fill in for LOCAL testing only. Do NOT commit a real .env file.
# In GitHub Actions these values come from repository secrets instead.

# --- Sensitive: store as GitHub secrets, keep out of source control ---
FABRIC_TENANT_ID=
FABRIC_CLIENT_ID=
FABRIC_CLIENT_SECRET=

# --- Deployment Pipeline + stage IDs (not secret, but kept here for convenience) ---
FABRIC_DEPLOYMENT_PIPELINE_ID=
FABRIC_DEV_STAGE_ID=
FABRIC_TEST_STAGE_ID=
FABRIC_PROD_STAGE_ID=

# --- Workspace IDs (also present in config/fabric-schedules.json) ---
FABRIC_DEV_WORKSPACE_ID=
FABRIC_TEST_WORKSPACE_ID=
FABRIC_PROD_WORKSPACE_ID=

# --- Optional: pipeline item IDs per stage (also present in config/fabric-schedules.json) ---
FABRIC_DEV_PIPELINE_ITEM_ID=
FABRIC_TEST_PIPELINE_ITEM_ID=
FABRIC_PROD_PIPELINE_ITEM_ID=
